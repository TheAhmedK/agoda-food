# ─── Bootstrap variables (stay in .env — needed before DB is reachable) ────────
# These are the ONLY variables the backend reads from the environment at runtime.
# Everything else is stored in the `app_config` MongoDB collection.
# See: src/config/keys.ts for the full list of configurable keys.

PORT=3000
MONGODB_URI=mongodb://localhost:27017/agoda-food

# NODE_ENV controls dev/prod behaviour (cors, static serving, OTP console log).
# Set to "production" in deployed environments.
# NODE_ENV=production

# ─── Seeding all other config into the database ─────────────────────────────
# On first setup, populate the remaining configuration keys into MongoDB:
#
#   1. Add the keys and values to this file temporarily (see full list below).
#   2. Run: npm run seed:config -w @agoda-food/backend
#   3. Remove the values from this file — they now live in the DB.
#
# To update a value later, use the mongo shell:
#   db.app_config.updateOne({ key: "JWT_SECRET" }, { $set: { value: "new-value" } })
#
# Or re-run seed:config after adding/changing values (existing DB keys are NOT
# overwritten, so delete the DB entry first if you want to reseed a key).
#
# Full list of configurable keys (all optional unless marked REQUIRED):
#
#   REQUIRED
#   LINE_CHANNEL_ID               LINE Login channel ID
#   LINE_CHANNEL_SECRET           LINE Login channel secret
#   LINE_LOGIN_REDIRECT_URI       Redirect URI on the LINE Login channel
#   JWT_SECRET                    Session signing secret (long random string)
#   LIFF_ID                       LIFF app ID (used in LINE bot deep-link buttons)
#
#   OPTIONAL (have defaults — see src/config/keys.ts)
#   JWT_EXPIRES_IN                default: 7d
#   OTP_TTL_MINUTES               default: 10
#   AGODA_EMAIL_DOMAIN            default: agoda.com
#   STRIPE_STATEMENT_DESCRIPTOR   default: AGODA FOOD
#   STRIPE_PROMPTPAY_QR_EXPIRY_MINUTES  default: 5
#   MAIL_FROM                     default: agodaminton@outlook.com
#   MAIL_FROM_NAME                default: Agoda Food
#   MAIL_DISABLED                 default: false
#   MAIL_SEND_TIMEOUT_MS          default: 15000
#
#   OPTIONAL (no default — feature disabled when absent)
#   LINE_MESSAGING_ACCESS_TOKEN
#   LINE_MESSAGING_CHANNEL_SECRET
#   PUBLIC_APP_URL
#   R2_ACCOUNT_ID
#   R2_ACCESS_KEY_ID
#   R2_SECRET_ACCESS_KEY
#   R2_BUCKET
#   R2_PUBLIC_ACCESS_KEY_ID
#   R2_PUBLIC_SECRET_ACCESS_KEY
#   R2_PUBLIC_BUCKET
#   R2_PUBLIC_BASE_URL
#   STRIPE_SECRET_KEY
#   STRIPE_WEBHOOK_SECRET
#   MAILJET_API_KEY
#   MAILJET_API_SECRET
